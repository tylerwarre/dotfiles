" Global keymaps
let mapleader = " "

" Checkbox commands
nnoremap <leader>cc :normal! 0t]rx<Esc>
nnoremap <leader>cu :normal! 0t]r<Space><Esc>

" Use a block cursor for all modes
set guicursor=n-v-c-i:block
" Allows dashes in tags
set iskeyword+=-
" Turn on line numbers
set number
" Less cowbell
set belloff=all
" Don't leave visual mode when indenting
vnoremap > >gv
vnoremap < <gv
" Set tabs and shiftwidth to 4 spaces
filetype plugin indent on
set tabstop=4
set shiftwidth=4
set expandtab
set softtabstop=4
" Tunn on syntax highlighting
syntax on

" Disable mouse
set mouse=

" Searching
"" Highlight as you type
set incsearch
"" Highlight all matches
set hlsearch

" Statusline
"" Always show the statusline
set laststatus=2
hi StatusLine cterm=bold ctermbg=DarkGrey ctermfg=White

" Shadow Files
"" No undo files
set noundofile
"" Remove backup files after they have been saved
set nobackup
set nowritebackup

" Spelling
"" MarkDown
autocmd FileType markdown setlocal spell

" Plugins
"" Load all plugins
"packloadall

" vim-table-mode
"let g:table_mode_corner='|'
