" Custom Vim Functions
command -complete=custom,GetChecklists -nargs=1 Checklists call Checklists(<f-args>)
fun GetChecklists(A,L,P)
	if has("win32") || has("win64")
		return system('dir /B /A-D ' . expand($HOME) . '\vimfiles\checklists\')
	else
		return system('ls -1 ' . expand($HOME) . '\.vim\checklists\')
	endif
endfunction

function Checklists(file)
	echo a:file
	if has("win32") || has("win64")
		execute 'r' expand($HOME) . '\vimfiles\checklists\' . a:file
	else
		execute 'r' expand($HOME) . '\.vim\checklists\' . a:file
	endif
endfunction

